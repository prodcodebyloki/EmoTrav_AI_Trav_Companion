# ── API Keys (required Day 1) ──────────────────────────────────────────────────
# Get from: https://aistudio.google.com → Get API Key
GOOGLE_API_KEY=

# Get from: GCP Console → APIs & Services → Credentials
# Enable: Places API (New), Geocoding API
GOOGLE_MAPS_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── GCP (Sprint 7 deployment only) ───────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
